# Anthropic API Key (Required for Mirror AI)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API Key (Required for Whisper voice transcription)
OPENAI_API_KEY=sk-...

# Supabase (Optional - for authenticated users, persistent data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PiAPI (Recommended for video) - https://piapi.ai
PIAPI_KEY=your_piapi_key
PIAPI_SERVICE_MODE=public  # or "private" for host-your-account

# Kling AI API (Official - fallback if PIAPI_KEY not set)
KLING_ACCESS_KEY=your_access_key
KLING_SECRET_KEY=your_secret_key

# Optional: Rate limiting
RATE_LIMIT_PER_DAY=50
